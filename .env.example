# ---------------------------------------------------------------------------
# ms-gateway-llm — environment template
# ---------------------------------------------------------------------------
# In development: copy this file to `.env` and fill in real values.
# In staging/production: the same variables live in Doppler under the
# project configured by MS / START_TOKEN. Doppler writes them into
# process.env at boot, which takes priority over this file.
# ---------------------------------------------------------------------------

# Project metadata (used by inyectEnv / Doppler SDK lookup)
MS=ms-proxy
# Service env. Maps to Doppler config: development->dev, staging->stg, production->prd
NODE_ENV=development
# Doppler PAT for the project. Required for staging/production. Omit on local dev
# and the service will fall back to .env only.
START_TOKEN=

# Sentry (optional)
SENTRY_DSN=

# ---------------------------------------------------------------------------
# LLM providers (Phase 2: registry-driven).
#
# Each provider in config/providers.json declares its own API key env var,
# e.g. `nan.apiKeyEnv = "NAN_API_KEY"`. Define one here per provider the
# gateway will route to. Missing values produce a startup error pointing at
# the missing key.
# ---------------------------------------------------------------------------

# Default provider (nan / builders).
NAN_API_KEY=
# openai provider — uncomment to enable.
# OPENAI_API_KEY=
# Deepseek / Anthropic / etc. follow the same pattern.

# Optional global default baseURL. Only used when a provider in the registry
# has no explicit `baseURL` set.
LLM_PROVIDER_BASE_URL=https://api.nan.builders/v1

# ---------------------------------------------------------------------------
# CORS allowlist
# Comma-separated list of origins that may call the gateway, or "*" to allow
# any origin. Leave empty in production unless you know what you are doing.
# ---------------------------------------------------------------------------
CORS_ORIGINS=*
